# Coordinator — this is the shared secret volunteers must present
# Generate one with: `openssl rand -base64 32`  (or PowerShell's RandomNumberGenerator on Windows)
COORDINATOR_SECRET=change-me-to-a-strong-random-string

# GitHub Actions self-hosted runner
GITHUB_ORG_NAME=<your-github-org>
GITHUB_PAT=<your-github-pat-with-admin:org-scope>
RUNNER_NAME=coordinator-runner